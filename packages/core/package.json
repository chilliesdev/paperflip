{
  "name": "@paperflip/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "react-native": "./src/database.ts",
      "import": "./dist/database.js",
      "require": "./dist/database.cjs"
    },
    "./segmenter": {
      "types": "./dist/segmenter.d.ts",
      "react-native": "./src/segmenter.ts",
      "import": "./dist/segmenter.js",
      "require": "./dist/segmenter.cjs"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "react-native": "./src/constants.ts",
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "react-native": "./src/types.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2"
  },
  "devDependencies": {
    "@paperflip/eslint-config": "workspace:*",
    "@paperflip/prettier-config": "workspace:*",
    "@paperflip/ts-config": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
