{
  "extends": [
    "@paperflip/ts-config/base.json",
    "expo/tsconfig.base"
  ],
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@paperflip/*": ["../../packages/*/src"]
    },
    "types": ["nativewind/types"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts"
  ]
}
