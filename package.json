{
  "name": "paperflip-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@paperflip/web",
    "dev:mobile": "turbo run dev --filter=@paperflip/mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "pnpm -r format",
    "check": "turbo run check",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "turbo": "^2.4.2"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@expo/metro-runtime": "~4.0.0",
    "react-dom": "19.2.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-web": "~0.19.13",
    "expo": "~55.0.8",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "version": "1.0.0"
}
